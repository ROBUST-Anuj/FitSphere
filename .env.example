# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Postgres ---
POSTGRES_DB=fitsphere
POSTGRES_USER=fitsphere
POSTGRES_PASSWORD=fitsphere
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- CORS (comma separated origins, no trailing slash) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Host port mappings (for docker-compose) ---
WEB_PORT=8000
